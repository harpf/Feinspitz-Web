# Kopiere diese Datei nach .env.local und trage das Application Password ein.
# .env.local ist gitignored — Secrets NIEMALS committen.

WP_BASE=https://feinspitz.alpenmesh.de
WP_USER=automation

# Application Password (wp-admin -> Benutzer -> Profil -> Anwendungspasswörter).
# Format mit Leerzeichen ist ok, z. B.: abcd EFGH ijkl MNOP qrst UVWX
WP_APP_PASSWORD=

# Login-Passwort (nur für cookie-basierten Theme-Upload via wp-admin nötig, da REST
# keinen Custom-Theme-Zip-Upload kennt). Optional, falls du nur Content pushst.
WP_LOGIN_PASSWORD=
