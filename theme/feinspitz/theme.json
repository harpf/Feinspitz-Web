{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": { "contentSize": "760px", "wideSize": "1280px" },
    "useRootPaddingAwareAlignments": true,
    "color": {
      "defaultPalette": false,
      "palette": [
        { "slug": "base", "color": "#0e0b08", "name": "Base (Espresso)" },
        { "slug": "contrast", "color": "#f6f1e7", "name": "Contrast (Cream)" },
        { "slug": "wine", "color": "#7b1f2b", "name": "Wine" },
        { "slug": "wine-deep", "color": "#4a1119", "name": "Wine Deep" },
        { "slug": "gold", "color": "#c9a24b", "name": "Gold" },
        { "slug": "sage", "color": "#7d8471", "name": "Sage" }
      ],
      "gradients": [
        { "slug": "wine-fade", "name": "Wine Fade", "gradient": "linear-gradient(135deg, #4a1119 0%, #7b1f2b 100%)" }
      ]
    },
    "typography": {
      "fluid": true,
      "defaultFontSizes": false,
      "fontFamilies": [
        { "slug": "heading", "name": "Heading", "fontFamily": "\"Fraunces\", Georgia, serif" },
        { "slug": "body", "name": "Body", "fontFamily": "\"Inter\", system-ui, sans-serif" }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1.125rem", "name": "Medium" },
        { "slug": "large", "size": "clamp(1.5rem, 1.2rem + 1.5vw, 2.25rem)", "name": "Large", "fluid": { "min": "1.5rem", "max": "2.25rem" } },
        { "slug": "x-large", "size": "clamp(2.25rem, 1.6rem + 3.2vw, 4rem)", "name": "X-Large", "fluid": { "min": "2.25rem", "max": "4rem" } },
        { "slug": "xx-large", "size": "clamp(3rem, 2rem + 5vw, 6rem)", "name": "XX-Large", "fluid": { "min": "3rem", "max": "6rem" } }
      ]
    },
    "spacing": {
      "units": ["px", "em", "rem", "vh", "vw", "%"],
      "spacingScale": { "steps": 8 }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--contrast)",
      "text": "var(--wp--preset--color--base)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "var(--wp--preset--font-size--medium)",
      "lineHeight": "1.65"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--heading)",
          "fontWeight": "600",
          "lineHeight": "1.1"
        }
      },
      "link": {
        "color": { "text": "var(--wp--preset--color--wine)" },
        "typography": { "textDecoration": "underline" }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--wine)",
          "text": "var(--wp--preset--color--contrast)"
        },
        "border": { "radius": "999px" },
        "spacing": { "padding": { "top": "0.85rem", "bottom": "0.85rem", "left": "1.75rem", "right": "1.75rem" } },
        "typography": { "fontWeight": "600", "textDecoration": "none" },
        ":hover": { "color": { "background": "var(--wp--preset--color--wine-deep)" } }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ],
  "customTemplates": []
}
